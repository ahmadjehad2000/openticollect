# openTIcollect — baseline configuration.
#
# Copy this file to .env and edit what you need:   cp .env.backup .env
# The platform runs fine with everything left blank — any collector that
# needs a key simply stays "misconfigured" until you add one. No value here
# is a secret; fill real credentials into your own .env (which is gitignored).
#
# Note: comments must be on their own line. An inline comment after an empty
# value would be read as the value by the .env parser.

# --- core ---
LISTEN_ADDR=:8080
DATABASE_PATH=./data/openticollect.db
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# Set both to require HTTP basic auth on the whole UI.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- read API ---
# Set a key to enable GET /api/* (findings, indicators, STIX 2.1 export).
# Clients authenticate with:  Authorization: Bearer <key>
API_KEY=

# --- notifiers ---
# WEBHOOK_URL: findings are POSTed here as JSON; empty disables the webhook.
WEBHOOK_URL=
# WEBHOOK_SECRET: if set, requests carry X-Webhook-Signature (HMAC-SHA256).
WEBHOOK_SECRET=
# WEBHOOK_MIN_SEVERITY / EMAIL_MIN_SEVERITY: info | warn | critical
WEBHOOK_MIN_SEVERITY=warn
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_TO: comma-separated recipients
SMTP_TO=
EMAIL_MIN_SEVERITY=critical

# --- collector API keys (omit any to leave that collector "misconfigured") ---
OTX_API_KEY=
ABUSEIPDB_API_KEY=
ABUSECH_AUTH_KEY=
PULSEDIVE_API_KEY=
INTELX_API_KEY=
# NVD_API_KEY is optional; it only raises the NVD rate limit.
NVD_API_KEY=

# --- sources you point at yourself ---
# WEBSCRAPER_URLS / SECRETSCAN_URLS: comma-separated URLs to scrape.
WEBSCRAPER_URLS=
SECRETSCAN_URLS=
# RSS_FEEDS / TELEGRAM_CHANNELS: blank uses a curated breach/leak default set.
RSS_FEEDS=
TELEGRAM_CHANNELS=
# X_NITTER_INSTANCES: comma-separated Nitter base URLs for the X collector.
X_NITTER_INSTANCES=
X_ACCOUNTS=

# --- dark web ---
# TOR_PROXY: e.g. socks5://127.0.0.1:9050 ; empty disables the onion watchlist.
TOR_PROXY=
# ONION_URLS: comma-separated .onion URLs (requires TOR_PROXY).
ONION_URLS=
# ENABLE_AHMIA: clear-net Ahmia search of .onion sites.
ENABLE_AHMIA=true
