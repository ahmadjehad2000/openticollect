# openTIcollect configuration. Copy to .env and edit.
# Comments must be on their own line; an inline comment after an empty
# value is kept as the value by the .env parser.

# --- core ---
LISTEN_ADDR=:8080
DATABASE_PATH=./data/openticollect.db
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# If both BASIC_AUTH_* are set, the whole UI requires basic auth.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Read API: when set, enables GET /api/* (findings, indicators, STIX export).
# Clients authenticate with: Authorization: Bearer <key>. Unset => API disabled.
API_KEY=

# --- notifiers ---
# WEBHOOK_URL: POST findings as JSON; empty disables the webhook.
WEBHOOK_URL=
# WEBHOOK_SECRET: if set, requests carry X-Webhook-Signature (hmac-sha256).
WEBHOOK_SECRET=
# WEBHOOK_MIN_SEVERITY: info | warn | critical
WEBHOOK_MIN_SEVERITY=warn
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_TO: comma-separated recipients
SMTP_TO=
# EMAIL_MIN_SEVERITY: info | warn | critical
EMAIL_MIN_SEVERITY=critical

# --- collectors (omit a key to leave that collector "misconfigured") ---
OTX_API_KEY=
ABUSEIPDB_API_KEY=
ABUSECH_AUTH_KEY=
PULSEDIVE_API_KEY=
INTELX_API_KEY=
# NVD_API_KEY is optional; it raises the NVD rate limit.
NVD_API_KEY=

# FETCH_WINDOW_DAYS: how far back time-windowed collectors (OTX, NVD,
# ThreatFox) pull content. Default 30.
FETCH_WINDOW_DAYS=30

# --- web scraping / feeds ---
# WEBSCRAPER_URLS: comma-separated URLs to scrape.
WEBSCRAPER_URLS=
# SECRETSCAN_URLS: comma-separated URLs to scan for exposed secrets/credentials.
SECRETSCAN_URLS=
# RSS_FEEDS: comma-separated. Defaults to a built-in security/breach watchlist
# if left unset; edit it here or on the Settings page to add your own.
RSS_FEEDS=https://www.databreaches.net/feed/,https://krebsonsecurity.com/feed/,https://www.bleepingcomputer.com/feed/,https://feeds.feedburner.com/TheHackersNews,https://www.darkreading.com/rss.xml,https://therecord.media/feed/

# --- telegram (keyless public-channel scrape) ---
# TELEGRAM_CHANNELS: comma-separated @channels or t.me/ links. Left blank, a
# curated default set of public leak/breach-intel channels is monitored
# (vxunderground, darkwebinformer_news, nusacloud). Set this to override.
TELEGRAM_CHANNELS=

# --- x / twitter (keyless scrape via Nitter) ---
# X requires a login to read, so the x collector goes through Nitter, the
# open-source X front-end. X_NITTER_INSTANCES: comma-separated Nitter base URLs
# (tried in order). Public instances are volatile and often Cloudflare-walled —
# a self-hosted Nitter is the most reliable. Empty leaves the x collector
# disabled. X_ACCOUNTS: optional comma-separated handles whose timelines are
# also scanned, in addition to the per-keyword search.
X_NITTER_INSTANCES=
X_ACCOUNTS=

# --- dark web ---
# TOR_PROXY: e.g. socks5://127.0.0.1:9050 ; empty disables the onion watchlist.
TOR_PROXY=
# ONION_URLS: comma-separated .onion URLs (requires TOR_PROXY).
ONION_URLS=
# ENABLE_AHMIA: clear-net Ahmia search of .onion sites.
ENABLE_AHMIA=true
