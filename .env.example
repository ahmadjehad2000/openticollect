# --- core ---
LISTEN_ADDR=:8080
DATABASE_PATH=./data/openticollect.db
LOG_LEVEL=info                   # debug|info|warn|error
BASIC_AUTH_USER=                 # if both set, the whole UI requires basic auth
BASIC_AUTH_PASS=

# --- notifiers ---
WEBHOOK_URL=                     # POST JSON; empty disables the webhook
WEBHOOK_SECRET=                  # if set: X-Webhook-Signature: hex(hmac-sha256(secret, body))
WEBHOOK_MIN_SEVERITY=warn        # info|warn|critical
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=                         # comma-separated recipients
EMAIL_MIN_SEVERITY=critical      # info|warn|critical

# --- collectors (omit a key to leave that collector "misconfigured") ---
OTX_API_KEY=
ABUSEIPDB_API_KEY=
ABUSECH_AUTH_KEY=
PULSEDIVE_API_KEY=
INTELX_API_KEY=
NVD_API_KEY=                     # optional; raises the NVD rate limit

# --- web scraping / feeds ---
WEBSCRAPER_URLS=                 # comma-separated URLs
RSS_FEEDS=https://www.databreaches.net/feed/,https://krebsonsecurity.com/feed/

# --- telegram (keyless public-channel scrape) ---
TELEGRAM_CHANNELS=               # comma-separated @channels or t.me/ links

# --- dark web ---
TOR_PROXY=                       # e.g. socks5://127.0.0.1:9050 ; empty disables the onion watchlist
ONION_URLS=                      # comma-separated .onion URLs (requires TOR_PROXY)
ENABLE_AHMIA=true                # clear-net Ahmia search of .onion sites
